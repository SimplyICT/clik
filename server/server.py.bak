"""
SimplyClik Standalone Server
Completely independent from all other projects.
"""
import json, bcrypt, secrets, os, re, uuid
from pathlib import Path
from http.server import HTTPServer, SimpleHTTPRequestHandler
from datetime import datetime, timezone
import mimetypes

mimetypes.add_type('application/javascript', '.js')
mimetypes.add_type('text/css', '.css')

ROOT = Path(__file__).resolve().parent.parent
ADMIN_BUILD = ROOT / "web-admin" / "build"
PORT = int(os.environ.get("PORT", 3001))

DB = dict(
    host="db.imkkhzxeggjxepbisoyy.supabase.co", port=5432,
    database="postgres", user="postgres",
    password="LQ9aty9wUewIMYWF", ssl_context=True
)


def db(sql, params=None):
    import pg8000
    conn = pg8000.connect(**DB)
    cur = conn.cursor()
    cur.execute(sql, params or [])
    try:
        rows = cur.fetchall()
        conn.commit()
        return rows
    except:
        conn.commit()
        return []
    finally:
        cur.close()
        conn.close()


class Handler(SimpleHTTPRequestHandler):
    def log_message(self, fmt, *args):
        pass  # quiet

    def do_OPTIONS(self):
        self.send_response(200)
        self.end_headers()

    def do_POST(self):
        if self.path == '/api/login':
            return self.handle_login()
        self.send_error(404)

    def handle_login(self):
        length = int(self.headers['Content-Length'])
        body = json.loads(self.rfile.read(length))
        email = body.get('email', '').strip().lower()
        pw = body.get('password', '')

        if not email or not pw:
            return self.json(400, {"error": "Email and password required"})

        try:
            rows = db("SELECT id, email, encrypted_password FROM auth.users WHERE email = %s", (email,))
            if not rows:
                return self.json(401, {"error": "Invalid credentials"})
            uid, db_email, pw_hash = rows[0]
            if not bcrypt.checkpw(pw.encode(), pw_hash.encode()):
                return self.json(401, {"error": "Invalid credentials"})

            token = secrets.token_hex(32)
            role_rows = db("SELECT role FROM public.user_roles WHERE user_id = %s", (uid,))
            is_admin = bool(role_rows and role_rows[0][0] == 'admin')

            return self.json(200, {
                "token": token,
                "user": {"id": str(uid), "email": db_email, "uid": str(uid)},
                "is_admin": is_admin
            })
        except Exception as e:
            return self.json(500, {"error": str(e)})

    def do_GET(self):
        path = self.path.split('?')[0]

        # API
        if path.startswith('/api/'):
            return self.json(404, {"error": "Not found"})

        # Static files from admin build
        if path == '/':
            path = '/index.html'
        full = ADMIN_BUILD / path.lstrip('/')
        if full.exists() and full.is_file():
            self.send_response(200)
            guess, _ = mimetypes.guess_type(str(full))
            self.send_header('Content-Type', guess or 'application/octet-stream')
            self.end_headers()
            with open(full, 'rb') as f:
                self.wfile.write(f.read())
            return

        # SPA fallback
        index = ADMIN_BUILD / 'index.html'
        if index.exists():
            self.send_response(200)
            self.send_header('Content-Type', 'text/html')
            self.end_headers()
            with open(index, 'rb') as f:
                self.wfile.write(f.read())
            return

        self.send_error(404)

    def json(self, status, data):
        self.send_response(status)
        self.send_header('Content-Type', 'application/json')
        self.end_headers()
        self.wfile.write(json.dumps(data).encode())


if __name__ == '__main__':
    print(f"\n  SimplyClik Admin Server")
    print(f"  URL: http://0.0.0.0:{PORT}")
    print(f"  Login: admin@simplyclik.local / Temp123!\n")
    HTTPServer(('0.0.0.0', PORT), Handler).serve_forever()
